# ============================================
# Discord Bot Environment Configuration
# ============================================
# Rename this file to .env and fill in your values
# DO NOT commit .env to version control!
# ============================================

# ==================== REQUIRED ====================

# Discord Bot Token (from Discord Developer Portal)
# https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ==================== AI (Claude / Anthropic) — Primary ====================

# Anthropic API Key (from Anthropic Console). Only needed if you opt OUT
# of the default CLI mode by setting CLAUDE_BACKEND=api below. The CLI
# default uses your Claude Code subscription instead of per-token billing.
# https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic Base URL (optional, for API proxy services)
# Only set this if you use a third-party proxy instead of api.anthropic.com
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Anthropic Direct / Proxy dual-endpoint failover (optional)
# When both DIRECT and PROXY keys are set, the bot fails over between them
# if one endpoint returns errors or rate-limits.
# ANTHROPIC_DIRECT_API_KEY=
# ANTHROPIC_PROXY_API_KEY=
# ANTHROPIC_PROXY_BASE_URL=https://your-proxy.example.com
# ANTHROPIC_API_ENDPOINT=https://api.anthropic.com

# Claude Model (optional, default: claude-opus-4-8)
CLAUDE_MODEL=claude-opus-4-8

# Model used for history summarization (optional, default: inherits CLAUDE_MODEL above)
# Override only if you want a cheaper/faster model than your main chat model —
# Haiku 4.5 costs ~20% of Opus 4.8 per token and is plenty for summarization.
# CLAUDE_SUMMARIZATION_MODEL=claude-haiku-4-5

# Claude context window in tokens (optional, default: 1000000)
# Opus 4.8 supports a 1M-token context window natively — no beta header
# required, and no long-context premium at standard API pricing. Lower this
# only if you target a model that caps at 200K.
# CLAUDE_CONTEXT_WINDOW=1000000

# Claude Max Output Tokens (optional, default: 128000)
CLAUDE_MAX_TOKENS=128000

# Claude effort level — Opus-tier parameter controlling reasoning depth and
# token spend. Values: low | medium | high | xhigh | max.
# DEFAULT IS "xhigh" (deep Opus-tier reasoning, one tier below "max"). Set
# another tier to trade reasoning depth for cost/latency: "max" for the very
# deepest reasoning, "high" as the minimum for intelligence-sensitive work.
# CLAUDE_EFFORT=xhigh

# Default AI Provider for dashboard (gemini or claude)
DEFAULT_AI_PROVIDER=claude

# ==================== Claude Backend (master switch) ====================
# Choose how the bot talks to Claude. This switch ALSO controls whether
# any other paid-API AI surface is initialized.
#
#   cli  → DEFAULT. Spawn `claude -p` subprocess; billing through your
#          Claude Code subscription. Disables ALL paid-API surfaces:
#          - Anthropic SDK (api_failover)
#          - Gemini SDK (RAG embeddings, dashboard Gemini provider)
#          - Memory consolidator (entity fact extraction)
#          - Conversation summarizer (long-history compression)
#          The dashboard Claude chat AND Discord-side AI replies both
#          run through the same `claude -p` subprocess. Discord-side
#          replies are text-only in CLI mode — image attachments to
#          Discord messages are dropped with a "[attachment omitted]"
#          marker in the prompt rather than re-uploaded to Claude. If
#          you need vision, set `CLAUDE_BACKEND=api` and an API key.
#   api  → Use the anthropic Python SDK with ANTHROPIC_API_KEY
#          (per-token billing). Enables every API-based subsystem.
#
# To use CLI mode (default):
#   1. Make sure `claude` CLI is installed and on PATH.
#   2. Run `claude` interactively at least once on this machine and complete
#      the browser login. The saved credentials in ~/.claude/.credentials.json
#      are picked up automatically by the spawned subprocess.
#   3. Restart the bot.
#
# CLI mode caveats:
#   - Shares quota with your interactive `claude` usage (rolling 5h window).
#   - No `temperature` / `max_tokens` flags (CLI does not expose them).
#   - No API failover (subscription auth has no proxy concept).
# Feature parity for dashboard chat (1M context, 128K output, vision,
# thinking, /edit, sessions, prompt caching) — see dashboard_chat_claude_cli.py.
CLAUDE_BACKEND=cli

# Optional: set this only if the bot runs as a different OS user than the one
# logged into Claude Code (e.g., a service account / Docker container).
# Generate with `claude setup-token` and copy the printed token here.
# CLAUDE_CODE_OAUTH_TOKEN=

# ==================== AI (Gemini) — Embeddings Only ====================

# Google Gemini API Key (optional, used for RAG embeddings only)
# https://aistudio.google.com/app/apikey
# Commented out so a verbatim ``cp env.example .env`` doesn't try to use the
# literal ``your_gemini_api_key_here`` string as a real key on startup.
# Uncomment and replace with your real key when enabling RAG.
# GEMINI_API_KEY=your_gemini_api_key_here

# Gemini chat model name (optional). Default in dashboard_config.py is
# gemini-3.1-pro-preview; override here if you need a different one.
# Embeddings use a separate model defined inside cogs/ai_core/memory/rag.py.
# GEMINI_MODEL=gemini-3.1-pro-preview

# Gemini context window in tokens (optional)
# GEMINI_CONTEXT_WINDOW=1000000

# ==================== Spotify (Optional) ====================
# Required only if you want Spotify link support

# Spotify API Credentials (from Spotify Developer Dashboard)
# https://developer.spotify.com/dashboard
# Commented out so a verbatim ``cp env.example .env`` doesn't make the
# Spotify client try to authenticate with placeholder credentials at
# startup. Uncomment and fill in when enabling Spotify link support.
# SPOTIPY_CLIENT_ID=your_spotify_client_id_here
# SPOTIPY_CLIENT_SECRET=your_spotify_client_secret_here

# ==================== Guild/Channel IDs ====================
# These control where AI features work
# Set to 0 to disable specific restrictions

# Main Guild - Full AI features including server management
GUILD_ID_MAIN=0

# Restricted Guild - AI only works in specific channel
GUILD_ID_RESTRICTED=0
CHANNEL_ID_ALLOWED=0

# Roleplay Server - Special RP mode with character switching
GUILD_ID_RP=0
CHANNEL_ID_RP_OUTPUT=0
CHANNEL_ID_RP_COMMAND=0

# Command-Only Guild - Must use !chat command (no auto-response)
GUILD_ID_COMMAND_ONLY=0

# ==================== Role IDs ====================
# Required for role-based features

ROLE_PLAYER_ID=0
ROLE_ADMIN_ID=0
ROLE_STAFF_ID_1=0
ROLE_STAFF_ID_2=0

# ==================== User IDs ====================

# Bot Creator/Owner ID (for special permissions)
CREATOR_ID=0

# ==================== Health API (Optional) ====================
# HTTP server for health checks and monitoring

# Port for Health API server (default: 8080)
HEALTH_API_PORT=8080

# Host for Health API server (default: 127.0.0.1 for local access only).
# Setting anything other than 127.0.0.1 / localhost / ::1 forces a bind to
# 127.0.0.1 anyway unless you ALSO set HEALTH_API_ALLOW_REMOTE=1 — this
# stops a copy-and-paste of "0.0.0.0" from accidentally exposing
# protected /metrics + /stats endpoints to the internet.
HEALTH_API_HOST=127.0.0.1
# HEALTH_API_ALLOW_REMOTE=1  # opt-in flag, required to bind non-loopback

# Bearer token for protected Health API endpoints.
# Leave empty → an ephemeral 32-byte token is generated at startup and
#   logged with an 8-char prefix. Protected endpoints (/metrics, /stats,
#   /health/deep, /ai/stats) still require Bearer auth; they're never served
#   anonymously even on 127.0.0.1.
# Set a value → stable token across restarts (required for Grafana / a
#   sidecar that needs the same secret each boot).
HEALTH_API_TOKEN=

# Dedicated Go health service endpoint (separate from the Python Health API above)
# Leave these at defaults unless you intentionally change the Go sidecar port/host.
GO_HEALTH_API_HOST=127.0.0.1
GO_HEALTH_API_PORT=8082

# ==================== Dashboard Security (Optional) ====================
# Settings for the WebSocket dashboard

# Auth token for WebSocket dashboard connections.
# Leave empty → EVERY WS connection is rejected with 401. The dashboard
#   simply won't work. This is fail-closed by design: there's no
#   anonymous mode.
# Set a value → required by every client; clients send it as
#   ``Authorization: Bearer <token>`` on the upgrade request.
# Pair this with the host/TLS settings below — without TLS the token
# travels in plaintext, so a non-loopback bind without certs is refused
# at startup regardless of whether this is set.
DASHBOARD_WS_TOKEN=

# Allow unrestricted/creative writing mode in dashboard (default: disabled)
# Set to 1 or true to enable
DASHBOARD_ALLOW_UNRESTRICTED=false

# Dashboard CLI file-write mode (CLAUDE_BACKEND=cli only). When enabled, the
# embedded `claude -p` can CREATE/EDIT files without the interactive "Allow?"
# prompt the chat UI can't answer. Files-only: Bash, the web tools, NotebookEdit
# and subagents are denied, and a PreToolUse guard hook (cli_write_guard.py)
# denies any write whose canonical path is outside DASHBOARD_CLI_WRITE_DIRS (so
# the repo, .env, ~/.claude, ~/.ssh and the home root are never writable).
# Default: disabled. Enable only on a trusted machine — uploaded documents are a
# prompt-injection surface that can drive writes WITHIN the allowed dirs.
DASHBOARD_CLI_ALLOW_WRITE=false
# Override the auto-approved write dirs (os.pathsep-separated: ';' on Windows,
# ':' on Linux). Default = your Desktop / Documents / Downloads, incl.
# OneDrive-redirected Desktop/Documents on Windows. Only existing dirs are used.
# DASHBOARD_CLI_WRITE_DIRS=C:\Users\You\Desktop;C:\Users\You\Projects

# Stream-read timeout (seconds) when the user enables Thinking on a
# dashboard chat turn. Opus 4.8 with --effort xhigh + interleaved-thinking
# can reason for several minutes before producing any stdout, so the
# normal 300s budget fires while the API call is still in flight.
# Floor is 300; default 1800.
DASHBOARD_STREAM_TIMEOUT_THINKING=1800

# Dashboard WebSocket host/port.
# Setting WS_DASHBOARD_HOST to anything other than 127.0.0.1 / localhost /
# ::1 will be FORCED back to 127.0.0.1 at startup unless BOTH
# WS_TLS_CERT_PATH and WS_TLS_KEY_PATH are set (and readable). This is
# refused-at-startup, not warn-and-continue, so a misconfigured deploy
# can't accidentally leak the auth token in plaintext.
WS_DASHBOARD_HOST=127.0.0.1
WS_DASHBOARD_PORT=8765

# Require TLS (WSS) for the dashboard WebSocket. When ``true``,
# WS_TLS_CERT_PATH and WS_TLS_KEY_PATH MUST point to readable PEM files
# or the WS server refuses to start. Setting this to ``true`` on a
# loopback bind is allowed (and pointless, but harmless).
WS_REQUIRE_TLS=false
# WS_TLS_CERT_PATH=/path/to/fullchain.pem
# WS_TLS_KEY_PATH=/path/to/privkey.pem

# ==================== Database (Optional) ====================

# SQLite connection timeout in seconds (default: 30)
# DB_CONNECTION_TIMEOUT=30

# ==================== URL Fetcher Sidecar (Optional) ====================
# Go microservice that safely fetches remote URLs (SSRF-hardened)

# URL_FETCHER_HOST is pinned to a small allowlist: ``localhost``, ``127.0.0.1``,
# ``::1``, ``url-fetcher`` (Docker service name). Any other value triggers a
# warning at startup and falls back to ``localhost`` — the bot's own request
# bodies travel over this connection, so we refuse to point the client at an
# arbitrary host even if the env is misconfigured.
# URL_FETCHER_HOST=127.0.0.1
# URL_FETCHER_PORT=8081
# Full override (takes precedence over HOST/PORT if set):
# GO_URL_FETCHER_URL=http://127.0.0.1:8081

# ==================== Alerting (Optional) ====================
# Webhook for operational alerts (Discord/Slack compatible)

# ALERT_WEBHOOK_URL=
# Minimum seconds between identical alerts (default: 300)
# ALERT_COOLDOWN_SECONDS=300

# ==================== Health Thresholds (Optional) ====================
# Tunables for the /health endpoint

# Maximum age in seconds before a heartbeat is considered stale (default: 60)
# HEALTH_HEARTBEAT_MAX_AGE=60
# Discord WebSocket latency ceiling in ms before reporting degraded (default: 5000)
# HEALTH_MAX_LATENCY_MS=5000

# ==================== Memory Monitor (Optional) ====================
# Background memory watchdog. When RSS crosses ``warning`` the bot logs
# a warning and runs registered cache-cleanup hooks; at ``critical`` it
# triggers a harder GC pass. Defaults target a typical 2 GiB container —
# raise these if you run on a 32 GiB workstation; lower them if you run
# in a tight ~512 MiB container so cleanup fires before the OOM killer.

# Soft warning threshold in MiB (default: 1024 = 1 GiB)
# BOT_MEMORY_WARNING_MB=1024
# Hard cleanup threshold in MiB (default: 1536 = 1.5 GiB)
# BOT_MEMORY_CRITICAL_MB=1536
# Poll interval in seconds (default: 30)
# BOT_MEMORY_CHECK_INTERVAL=30

# ==================== RAG / Vector Memory (Optional) ====================
# The FAISS index sidecar (``data/faiss/id_map.json``) is JSON since
# v3.3.x. Older bots wrote a legacy ``id_map.npy`` (pickle) that the
# loader will refuse to deserialize by default — pickle from any file
# on disk is an RCE sink. Set this to 1/true/yes ONLY when migrating a
# trusted pre-v3.3 deployment; remove it after the next clean save
# (which writes JSON and deletes the .npy).
# RAG_ALLOW_LEGACY_PICKLE=0

# ==================== Error Tracking (Optional) ====================

# Sentry DSN for error tracking and performance monitoring
# https://sentry.io/
# SENTRY_DSN=
# Default to ``development`` instead of ``production`` so a fresh
# ``cp env.example .env`` doesn't tag local-dev errors as production
# events in Sentry. Override to ``production`` only on the real
# deployment environment.
SENTRY_ENVIRONMENT=development
