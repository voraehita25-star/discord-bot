# ============================================
# Discord Bot Environment Configuration
# ============================================
# Rename this file to .env and fill in your values
# DO NOT commit .env to version control!
# ============================================

# ==================== REQUIRED ====================

# Discord Bot Token (from Discord Developer Portal)
# https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ==================== AI (Claude / Anthropic) — Primary ====================

# Anthropic API Key (from Anthropic Console) — REQUIRED for the Discord AI cog
# (!chat, RP mode, summarization, etc.) and for the dashboard chat in API mode.
# Optional ONLY if every Claude path runs in CLI mode (CLAUDE_BACKEND=cli) AND
# you don't use the bot's Discord-side AI features.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic Base URL (optional, for API proxy services)
# Only set this if you use a third-party proxy instead of api.anthropic.com
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Anthropic Direct / Proxy dual-endpoint failover (optional)
# When both DIRECT and PROXY keys are set, the bot fails over between them
# if one endpoint returns errors or rate-limits.
# ANTHROPIC_DIRECT_API_KEY=
# ANTHROPIC_PROXY_API_KEY=
# ANTHROPIC_PROXY_BASE_URL=https://your-proxy.example.com
# ANTHROPIC_API_ENDPOINT=https://api.anthropic.com

# Claude Model (optional, default: claude-opus-4-7)
CLAUDE_MODEL=claude-opus-4-7

# Model used for history summarization (optional, default: claude-haiku-4-5)
# CLAUDE_SUMMARIZATION_MODEL=claude-haiku-4-5

# Claude context window in tokens (optional, default: 1000000)
# Opus 4.7 supports 1M context with subscription auth or `betas: context-1m`
# on the API. Lower this if you target a model that caps at 200K.
# CLAUDE_CONTEXT_WINDOW=1000000

# Claude Max Output Tokens (optional, default: 128000)
CLAUDE_MAX_TOKENS=128000

# Claude effort level — Opus 4.7 parameter controlling token spend.
# Values: low | medium | high | xhigh | max  (blank = use API default "high")
# Opus 4.7 docs recommend "xhigh" for coding/agentic workloads and "high"
# as the minimum for intelligence-sensitive workloads. Only 4.7 supports xhigh.
# Note: Opus 4.7 uses a new tokenizer that produces 1.0–1.35× more tokens
# per same input than 4.6, so budget accordingly.
# CLAUDE_EFFORT=high

# Default AI Provider for dashboard (gemini or claude)
DEFAULT_AI_PROVIDER=claude

# ==================== Dashboard Claude Backend (Optional) ====================
# Choose how the dashboard's Claude provider talks to Anthropic.
#   api  → use the anthropic Python SDK with ANTHROPIC_API_KEY (per-token billing). DEFAULT.
#   cli  → spawn `claude -p` subprocess, billing through your Claude Code subscription.
#          NO per-token charge — uses your Max plan quota instead.
#
# To enable CLI mode:
#   1. Make sure `claude` CLI is installed and on PATH.
#   2. Run `claude` interactively at least once on this machine and complete
#      the browser login. The saved credentials in ~/.claude/.credentials.json
#      are picked up automatically by the spawned subprocess.
#   3. Set CLAUDE_BACKEND=cli below.
#   4. Restart the bot.
#
# CLI mode caveats:
#   - Shares quota with your interactive `claude` usage (rolling 5h window).
#   - No `temperature` / `max_tokens` flags (CLI does not expose them).
#   - No API failover (subscription auth has no proxy concept).
# Feature parity for the rest (1M context, 128K output, vision, thinking,
# /edit, sessions, prompt caching) — see dashboard_chat_claude_cli.py.
CLAUDE_BACKEND=api

# Optional: set this only if the bot runs as a different OS user than the one
# logged into Claude Code (e.g., a service account / Docker container).
# Generate with `claude setup-token` and copy the printed token here.
# CLAUDE_CODE_OAUTH_TOKEN=

# ==================== AI (Gemini) — Embeddings Only ====================

# Google Gemini API Key (optional, used for RAG embeddings only)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name for embeddings (optional)
# GEMINI_MODEL=gemini-2.0-flash-exp

# Gemini context window in tokens (optional)
# GEMINI_CONTEXT_WINDOW=1000000

# ==================== Spotify (Optional) ====================
# Required only if you want Spotify link support

# Spotify API Credentials (from Spotify Developer Dashboard)
# https://developer.spotify.com/dashboard
SPOTIPY_CLIENT_ID=your_spotify_client_id_here
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret_here

# ==================== Guild/Channel IDs ====================
# These control where AI features work
# Set to 0 to disable specific restrictions

# Main Guild - Full AI features including server management
GUILD_ID_MAIN=0

# Restricted Guild - AI only works in specific channel
GUILD_ID_RESTRICTED=0
CHANNEL_ID_ALLOWED=0

# Roleplay Server - Special RP mode with character switching
GUILD_ID_RP=0
CHANNEL_ID_RP_OUTPUT=0
CHANNEL_ID_RP_COMMAND=0

# Command-Only Guild - Must use !chat command (no auto-response)
GUILD_ID_COMMAND_ONLY=0

# ==================== Role IDs ====================
# Required for role-based features

ROLE_PLAYER_ID=0
ROLE_ADMIN_ID=0
ROLE_STAFF_ID_1=0
ROLE_STAFF_ID_2=0

# ==================== User IDs ====================

# Bot Creator/Owner ID (for special permissions)
CREATOR_ID=0

# ==================== Health API (Optional) ====================
# HTTP server for health checks and monitoring

# Port for Health API server (default: 8080)
HEALTH_API_PORT=8080

# Host for Health API server (default: 127.0.0.1 for local access only)
# Use 0.0.0.0 to allow external access (NOT recommended without auth)
HEALTH_API_HOST=127.0.0.1

# Bearer token for protected Health API endpoints
# Strongly recommended if you bind HEALTH_API_HOST to anything other than localhost
HEALTH_API_TOKEN=

# Dedicated Go health service endpoint (separate from the Python Health API above)
# Leave these at defaults unless you intentionally change the Go sidecar port/host.
GO_HEALTH_API_HOST=127.0.0.1
GO_HEALTH_API_PORT=8082

# ==================== Dashboard Security (Optional) ====================
# Settings for the WebSocket dashboard

# Auth token for WebSocket dashboard connections
# If set, clients must provide this token to connect
DASHBOARD_WS_TOKEN=

# Allow unrestricted/creative writing mode in dashboard (default: disabled)
# Set to 1 or true to enable
DASHBOARD_ALLOW_UNRESTRICTED=false

# Dashboard WebSocket host/port
WS_DASHBOARD_HOST=127.0.0.1
WS_DASHBOARD_PORT=8765

# Require TLS (WSS) for the dashboard WebSocket. Strongly recommended when
# WS_DASHBOARD_HOST is not 127.0.0.1. When enabled, WS_TLS_CERT_PATH and
# WS_TLS_KEY_PATH must point to readable PEM files.
WS_REQUIRE_TLS=false
# WS_TLS_CERT_PATH=/path/to/fullchain.pem
# WS_TLS_KEY_PATH=/path/to/privkey.pem

# ==================== Database (Optional) ====================

# SQLite connection timeout in seconds (default: 30)
# DB_CONNECTION_TIMEOUT=30

# ==================== URL Fetcher Sidecar (Optional) ====================
# Go microservice that safely fetches remote URLs (SSRF-hardened)

# URL_FETCHER_HOST=127.0.0.1
# URL_FETCHER_PORT=8081
# Full override (takes precedence over HOST/PORT if set):
# GO_URL_FETCHER_URL=http://127.0.0.1:8081

# ==================== Alerting (Optional) ====================
# Webhook for operational alerts (Discord/Slack compatible)

# ALERT_WEBHOOK_URL=
# Minimum seconds between identical alerts (default: 300)
# ALERT_COOLDOWN_SECONDS=300

# ==================== Health Thresholds (Optional) ====================
# Tunables for the /health endpoint

# Maximum age in seconds before a heartbeat is considered stale (default: 60)
# HEALTH_HEARTBEAT_MAX_AGE=60
# Discord WebSocket latency ceiling in ms before reporting degraded (default: 500)
# HEALTH_MAX_LATENCY_MS=500

# ==================== Error Tracking (Optional) ====================

# Sentry DSN for error tracking and performance monitoring
# https://sentry.io/
# SENTRY_DSN=
SENTRY_ENVIRONMENT=production
